{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meshtastic-noc/shared/events/v1/command.schema.json",
  "title": "CommandEnvelope",
  "description": "Comandos backend -> gateway. Entregados por Redis Stream 'noc:commands:<gateway_id>' con consumer group. El gateway reporta el resultado publicando un evento.",
  "type": "object",
  "required": ["schema_version", "command_type", "command_id", "issued_by", "timestamp", "payload"],
  "properties": {
    "schema_version": { "const": 1 },
    "command_type": {
      "type": "string",
      "enum": ["command.send_admin", "command.request_position", "command.traceroute", "command.send_text"]
    },
    "command_id": { "type": "string", "format": "uuid" },
    "issued_by": { "type": "string", "description": "Usuario que originó el comando (para auditoría)" },
    "timestamp": { "type": "string", "format": "date-time" },
    "target_node_id": { "type": ["string", "null"], "pattern": "^![0-9a-f]{8}$" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
