# ── Despliegue ───────────────────────────────────────────────
# Puerto HTTP de entrada (nginx)
NOC_HTTP_PORT=8080
NOC_LOG_LEVEL=INFO

# ── Base de datos ────────────────────────────────────────────
# PostgreSQL (recomendado, ADR 0004):
POSTGRES_USER=noc
POSTGRES_PASSWORD=noc
POSTGRES_DB=noc
NOC_DATABASE_URL=postgresql+asyncpg://noc:noc@postgres:5432/noc
# Alternativa SQLite (ligera, sin contenedor postgres):
# NOC_DATABASE_URL=sqlite+aiosqlite:////data/noc.db

# ── Dashboard NOC (umbrales) ─────────────────────────────────
# Batería considerada baja (%)
LOW_BATTERY_THRESHOLD=20
# Un nodo sin actividad durante más de estos minutos requiere atención
OFFLINE_MINUTES_WARNING=30
# % de nodos offline que degrada el estado global a WARNING / CRITICAL
OFFLINE_PERCENT_WARNING=5
OFFLINE_PERCENT_CRITICAL=20
# SNR (dB) por debajo del cual un nodo se considera degradado
SNR_DEGRADED_THRESHOLD=-15

# ── Administración remota (M1.1) ─────────────────────────────
# Presupuesto de malla: operaciones remotas despachadas por minuto (global).
# Techo de seguridad, no el throughput real (también limita "1 operación en
# vuelo por gateway" + la latencia real de cada roundtrip). Con presets
# rápidos (EU_868) el 10% de duty cycle admite bastante más que esto; subir
# si hace falta.
NOC_ADMIN_RATE_LIMIT_PER_MINUTE=60
NOC_ADMIN_DEFAULT_TIMEOUT_SECONDS=120
NOC_ADMIN_MAX_ATTEMPTS=3

# ── Motor de alertas ─────────────────────────────────────────
# Cadencia de evaluación de reglas (segundos). Las reglas se gestionan en BD
# (sembradas desde los umbrales de arriba) y los canales (webhook/ntfy) por API/UI.
NOC_ALERT_EVAL_INTERVAL_SECONDS=30

# ── Registro persistente (hardening) ─────────────────────────
# Tope de filas de activity_log: el diario del Registro sobrevive a recargas
# pero se poda al superar este tamaño (no es un histórico ilimitado).
NOC_ACTIVITY_LOG_MAX_ROWS=20000

# ── Autenticación ────────────────────────────────────────────
# Sin flag de activación: el modo protegido se enciende solo al existir un
# usuario admin habilitado (y se apaga si deja de existir — válvula de
# seguridad, ver ADR 0024). Estos son los ajustes de sesión y rate limit.
#NOC_SESSION_COOKIE_NAME=ms_session
#NOC_SESSION_IDLE_HOURS=12
#NOC_SESSION_MAX_DAYS=7
# false porque el stack sirve HTTP plano; con TLS delante ponlo SIEMPRE a true
# (sobre http:// una cookie Secure no se guarda y el login queda roto en silencio).
#NOC_COOKIE_SECURE=false
#NOC_PASSWORD_MIN_LENGTH=10
#NOC_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
#NOC_LOGIN_RATE_LIMIT_PER_USERNAME=5
#NOC_LOGIN_RATE_LIMIT_PER_IP=20

# ── Pasarela Meshtastic ──────────────────────────────────────
GATEWAY_ID=gw-01
# simulator | usb | tcp | http  (http: fase futura)
GATEWAY_TRANSPORT=simulator

# USB (GATEWAY_TRANSPORT=usb). Vacío = autodetección oficial (findPorts).
# Con valor (p. ej. /dev/ttyACM0) se usa ese dispositivo exacto.
# Recuerda mapear el dispositivo en docker-compose.yml (bloque `devices:`).
MESHTASTIC_USB_DEVICE=

# Reconexión con backoff exponencial (segundos)
MESHTASTIC_RECONNECT_INITIAL_DELAY=5
MESHTASTIC_RECONNECT_MAX_DELAY=300

# TCP (GATEWAY_TRANSPORT=tcp): nodo accesible por red (WiFi/Ethernet).
# Host obligatorio (IP o mDNS). OJO: el firmware solo admite UN cliente TCP
# simultáneo — cierra la app oficial si está conectada al mismo nodo.
GATEWAY_TCP_HOST=
GATEWAY_TCP_PORT=4403

# ── Simulador Multi-Gateway (M6.2) ───────────────────────────
# Semilla de la malla exclusiva de ESTA pasarela. Dos procesos simulados
# deben usar semillas distintas (misma semilla = mismos node_id ficticios
# pisándose entre pasarelas).
GATEWAY_SIM_SEED=42
# Semilla común de nodos COMPARTIDOS: todos los procesos gateway que la
# configuren con el mismo valor (≠0) generan además los mismos nodos SHRxx,
# visibles por varias pasarelas a la vez — es el mecanismo para validar la
# lógica Multi-Gateway (node_gateway_links, selección de pasarela, reparto
# de lotes) sin hardware. 0 = desactivado (comportamiento anterior).
GATEWAY_SIM_SHARED_SEED=0
GATEWAY_SIM_SHARED_NODE_COUNT=4
