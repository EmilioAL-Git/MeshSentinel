# ── Despliegue ───────────────────────────────────────────────
# Puerto HTTP de entrada (nginx)
NOC_HTTP_PORT=8080
NOC_LOG_LEVEL=INFO

# ── Base de datos ────────────────────────────────────────────
# PostgreSQL (recomendado, ADR 0004):
POSTGRES_USER=noc
POSTGRES_PASSWORD=noc
POSTGRES_DB=noc
NOC_DATABASE_URL=postgresql+asyncpg://noc:noc@postgres:5432/noc
# Alternativa SQLite (ligera, sin contenedor postgres):
# NOC_DATABASE_URL=sqlite+aiosqlite:////data/noc.db

# ── Dashboard NOC (umbrales) ─────────────────────────────────
# Batería considerada baja (%)
LOW_BATTERY_THRESHOLD=20
# Un nodo sin actividad durante más de estos minutos requiere atención
OFFLINE_MINUTES_WARNING=30
# % de nodos offline que degrada el estado global a WARNING / CRITICAL
OFFLINE_PERCENT_WARNING=5
OFFLINE_PERCENT_CRITICAL=20
# SNR (dB) por debajo del cual un nodo se considera degradado
SNR_DEGRADED_THRESHOLD=-15

# ── Administración remota (M1.1) ─────────────────────────────
# Presupuesto de malla: operaciones remotas despachadas por minuto (global)
NOC_ADMIN_RATE_LIMIT_PER_MINUTE=6
NOC_ADMIN_DEFAULT_TIMEOUT_SECONDS=120
NOC_ADMIN_MAX_ATTEMPTS=3

# ── Motor de alertas ─────────────────────────────────────────
# Cadencia de evaluación de reglas (segundos). Las reglas se gestionan en BD
# (sembradas desde los umbrales de arriba) y los canales (webhook/ntfy) por API/UI.
NOC_ALERT_EVAL_INTERVAL_SECONDS=30

# ── Pasarela Meshtastic ──────────────────────────────────────
GATEWAY_ID=gw-01
# simulator | usb | tcp | http  (tcp/http: fases futuras)
GATEWAY_TRANSPORT=simulator

# USB (GATEWAY_TRANSPORT=usb). Vacío = autodetección oficial (findPorts).
# Con valor (p. ej. /dev/ttyACM0) se usa ese dispositivo exacto.
# Recuerda mapear el dispositivo en docker-compose.yml (bloque `devices:`).
MESHTASTIC_USB_DEVICE=

# Reconexión con backoff exponencial (segundos)
MESHTASTIC_RECONNECT_INITIAL_DELAY=5
MESHTASTIC_RECONNECT_MAX_DELAY=300

GATEWAY_TCP_HOST=
GATEWAY_TCP_PORT=4403
